# ── Backend keys (copy to backend/.env) ───────────────────────────────────────

# WAQI (World Air Quality Index) token
# Free token: https://aqicn.org/data-platform/token/
# "demo" works for testing but is rate-limited and returns limited cities.
WAQI_TOKEN=demo

# Google Gemini API key
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Frontend keys (copy to frontend/.env) ─────────────────────────────────────

# ArcGIS API key (must be prefixed VITE_ for Vite to expose it)
# Get yours at: https://developers.arcgis.com/
# Required scope: Basemaps
VITE_ARCGIS_API_KEY=your_arcgis_api_key_here

# Backend API URL — no trailing slash, required in all environments
# Development: copy this file to frontend/.env and set to http://localhost:8000
# Production: already set in frontend/.env.production
VITE_API_URL=https://texas-aqi-backend.onrender.com
